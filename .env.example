# Vite dev: proxy /api to this URL. Default http://127.0.0.1:3001 = server/dev-api.mjs (OTP + PHP proxy).
VITE_PHP_HOST=http://127.0.0.1:3001

# When using dev-api on port 3001, forward /api/dashboard/* etc. to your live PHP host (origin only):
# PHP_API_UPSTREAM=https://your-production-domain.com
